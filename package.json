{
  "name": "mcp-discovery-registry",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "build": "npm run build --workspace @mcp-registry/shared && npm run build --workspace @mcp-registry/server && npm run build --workspace @mcp-registry/client",
    "typecheck": "node ./node_modules/typescript/bin/tsc -b --pretty false",
    "lint": "node ./node_modules/eslint/bin/eslint.js . --ext .ts,.tsx",
    "test": "npm run test --workspace @mcp-registry/server && npm run test --workspace @mcp-registry/client",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.7.5",
    "@vitest/coverage-v8": "^2.1.3",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.10.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "vitest": "^2.1.3"
  }
}
